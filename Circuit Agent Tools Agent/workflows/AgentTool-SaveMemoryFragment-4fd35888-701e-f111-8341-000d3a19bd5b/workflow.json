          "type": "InitializeVariable",
          "inputs": {
            "variables": [
              {
                "name": "sanitizedPath",
                "type": "string",
                "value": "@if(startsWith(\n  triggerBody()?[\u0027text\u0027], \u0027/\u0027), \n  triggerBody()?[\u0027text\u0027], \n  concat(\u0027/\u0027, triggerBody()?[\u0027text\u0027])\n)"
              }
            ]
          },
          "runAfter": {
            "Initialize_Memory_Root_Path": [
              "Succeeded"
            ]
          }
        }
