        "Ensure_Extension_on_Memory_Fragment_File": {
          "type": "InitializeVariable",
          "inputs": {
            "variables": [
              {
                "name": "sanitizedFileName",
                "type": "string",
                "value": "@\nif(\n  or(empty(triggerBody()?[\u0027text_1\u0027]), endsWith(triggerBody()?[\u0027text_1\u0027], \u0027/\u0027)),\n  triggerBody()?[\u0027text_1\u0027],\n  if(\n    contains(last(split(triggerBody()?[\u0027text_1\u0027], \u0027/\u0027)), \u0027.\u0027),\n    triggerBody()?[\u0027text_1\u0027],\n    concat(triggerBody()?[\u0027text_1\u0027], \u0027.md\u0027)\n  )\n)\n"
              }
            ]
          },
          "runAfter": {
            "Initialize_Memory_Fragments_Path": [
